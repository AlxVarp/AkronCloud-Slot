# Required
SLOT_TENANT_ID=00000000-0000-0000-0000-000000000001
SLOT_SLOT_ID=00000000-0000-0000-0000-0000000000aa

# 32+ byte random secret for HS256 JWT verification.
# Generate: openssl rand -base64 48
SLOT_JWT_SECRET=replace-me-with-a-real-secret-min-32-bytes

# Base64 of 32 raw bytes for AES-256-GCM (master key for HKDF).
# Generate: openssl rand -base64 32
SLOT_ENCRYPTION_KEY=replace-me-with-base64-of-32-bytes

# Optional (defaults shown)
# SLOT_BIND=127.0.0.1
# SLOT_PORT=7777
# SLOT_STATE_DB=/var/lib/akron-slot/state.db
# SLOT_LOG_LEVEL=info
# SLOT_RECONCILE_INTERVAL_MS=30000

# MT5 transport — Phase C / Ruta B1
# SLOT_BRIDGE: 'file' (legacy ZMQ + MQL5/Files) or 'tcp' (Phase C target).
# Default 'file' for backwards compatibility; switch to 'tcp' once the
# TCP path is validated in production.
# SLOT_BRIDGE=tcp
# SLOT_MT5_TCP_HOST=127.0.0.1
# SLOT_MT5_TCP_PORT=7778
# SLOT_MT5_CMD_TIMEOUT_MS=5000

# Risk limits (JSON). Empty / permissive defaults:
# SLOT_RISK_LIMITS_JSON={"max_position_size":0,"max_daily_loss_pct":100,"kill_switch_active":false}
