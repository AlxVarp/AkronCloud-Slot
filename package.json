{
  "name": "@akroncloud/slot-service",
  "version": "0.1.0",
  "description": "Pure REST + WebSocket trading service for AkronCloud. Runs on every tenant VPS. Connects to a broker (Deriv MVP), maintains an internal ledger, exposes a unified trading interface to the cerebro.",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "dev:token": "tsx scripts/dev-token.ts",
    "dev:health": "tsx -e \"fetch('http://127.0.0.1:7777/v1/health').then(r=>r.json()).then(j=>console.log(JSON.stringify(j)))\"",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/websocket": "^10.0.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.32.0",
    "fastify": "^4.28.0",
    "jose": "^5.9.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "ws": "^8.18.0",
    "zeromq": "^6.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "SPEC.md",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlxVarp/AkronCloud-Slot.git"
  },
  "keywords": [
    "akroncloud",
    "trading",
    "broker",
    "deriv",
    "mt5",
    "brokerage-as-a-service",
    "rest",
    "websocket",
    "multi-tenant"
  ],
  "author": "AlxVarp",
  "license": "MIT"
}
